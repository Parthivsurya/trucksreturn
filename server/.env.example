# Required: 'production' or 'development'. Server refuses to start if unset.
NODE_ENV=development

# Server port
PORT=3001

# REQUIRED: must be ≥32 chars and not a known placeholder.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_output_of_openssl_rand_hex_32

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Allowed CORS origin for the frontend (defaults to http://localhost:5173)
ALLOWED_ORIGIN=http://localhost:5173

# Admin credentials. In production: ADMIN_PASSWORD must be ≥12 chars and not weak.
# Generate with: openssl rand -base64 12
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace_with_strong_password
